# .env.example — Template for environment variables
# Copy to .env and fill in your values. NEVER commit .env.

# ─── Required for live trading ───────────────────────────────
PRIVATE_KEY=0x...                   # Polygon wallet private key
POLY_API_KEY=...                    # Derived L2 API key
POLY_SECRET=...                     # Derived L2 secret
POLY_PASSPHRASE=...                 # Derived L2 passphrase

# ─── Required for notifications ──────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ─── LLM API keys (priority: OpenRouter > Anthropic > Ollama) ───
OPENROUTER_API_KEY=sk-or-v1-...   # Recommended — replaces Ollama + Anthropic
OPENROUTER_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_HOST=https://openrouter.ai/api/v1

# ─── Optional — Claude API (falls back to Ollama if absent) ──
ANTHROPIC_API_KEY=...

# ─── Trading parameters (defaults shown) ─────────────────────
TRADING_MODE=paper                  # paper | live  (default: paper)
MIN_EDGE_THRESHOLD=0.08
KELLY_FRACTION=0.25
MAX_POSITION_USDC=50.0
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=0.10
MIN_MARKET_VOLUME=500.0
MIN_DAYS_TO_RESOLVE=0.1
POST_CANCEL_WAIT_SECONDS=5
STALE_ORDER_MAX_AGE_MIN=30

# ─── Scheduler intervals ────────────────────────────────────
SCAN_INTERVAL_MINUTES=15
LLM_PARSE_INTERVAL_MINUTES=30
STALE_ORDER_CHECK_MINUTES=10

# ─── Rate limits (calls per hour per source) ─────────────────
RATE_LIMIT_OPEN_METEO=200
RATE_LIMIT_NOAA=100
RATE_LIMIT_GAMMA=60
RATE_LIMIT_CLOB=120

# ─── LLM ─────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Polymarket ──────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ─── Database ────────────────────────────────────────────────
DB_PATH=db/trades.db
